---
import '../styles/styles.css';

export interface Props {
  title: string;
  description?: string;
  hideNav?: boolean;
}
const { title, description = 'همر | هوش مصنوعی موبایل — مشاور خرید Samsung، Apple و Xiaomi', hideNav = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/png" href="/assets/hmr-logo.png" />
  <style is:global>
    /* Compatibility aliases — map old shorthand to HMR design tokens */
    :root {
      --bg:     var(--surface-page);
      --card:   var(--surface-card);
      --border: var(--border-subtle);
      --text:   var(--text-body);
      --muted:  var(--text-muted);
      --cyan:   var(--hmr-cyan);
      --pink:   var(--hmr-pink);
      --purple: var(--hmr-violet);
    }

    /* Glow blobs */
    #particles { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
    .glow { position: fixed; border-radius: 50%; filter: blur(120px); opacity: 0.28; z-index: 0; pointer-events: none; }
    .glow-1 { width: 480px; height: 480px; background: var(--hmr-cyan);   top: -130px; left: -110px; }
    .glow-2 { width: 440px; height: 440px; background: var(--hmr-indigo); bottom: -150px; right: -120px; }
    .glow-3 { width: 340px; height: 340px; background: var(--hmr-blue);   top: 40%; left: 60%; opacity: 0.14; }

    .wrap { position: relative; z-index: 2; max-width: 1100px; margin: 0 auto; padding: 0 24px; }

    /* nav */
    nav {
      display: flex; align-items: center; justify-content: space-between;
      padding: 26px 0; flex-wrap: wrap; gap: 12px;
    }
    .logo {
      font-weight: 700; font-size: 1.45rem; letter-spacing: 0.04em;
      background: var(--gradient-brand);
      -webkit-background-clip: text; background-clip: text; color: transparent;
      text-decoration: none;
    }
    .nav-links { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
    .nav-link {
      font: inherit; font-size: 0.88rem; color: var(--text-muted);
      text-decoration: none; padding: 7px 14px; border-radius: 8px;
      transition: color .2s, background .2s; cursor: pointer; border: 0; background: transparent;
    }
    .nav-link:hover, .nav-link.active { color: var(--hmr-cyan); background: rgba(0,212,255,0.07); }
    .nav-link.cta-nav {
      background: var(--gradient-cta);
      color: var(--text-on-accent) !important; font-weight: 600; padding: 7px 18px;
      border-radius: 10px;
    }
    /* فارسی-تنها: محتوای انگلیسی پنهان */
    .en { display: none !important; }

    /* footer */
    footer {
      position: relative; z-index: 2; text-align: center;
      color: var(--text-muted); font-size: 0.84rem; padding: 30px 0 40px;
      border-top: 1px solid var(--border-hairline);
    }
    footer .footer-links { display: flex; justify-content: center; gap: 20px; margin-bottom: 12px; flex-wrap: wrap; }
    footer a { color: var(--text-muted); text-decoration: none; transition: color .2s; }
    footer a:hover { color: var(--hmr-cyan); }

    /* shared card */
    .card {
      background: var(--surface-card); border: 1px solid var(--border-subtle);
      border-radius: 18px; padding: 30px 26px; backdrop-filter: blur(14px);
      transition: transform .25s, border-color .25s, box-shadow .25s;
    }
    .card:hover {
      transform: translateY(-4px); border-color: var(--border-glow);
      box-shadow: 0 16px 50px rgba(0,212,255,0.1);
    }
    .badge {
      display: inline-block; font-size: 0.78rem; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--hmr-cyan);
      padding: 7px 16px; border: 1px solid var(--border-subtle); border-radius: 999px;
      background: rgba(0,212,255,0.06); margin-bottom: 24px;
    }
    .cta {
      display: inline-flex; align-items: center; gap: 10px;
      font: inherit; font-size: 1.02rem; font-weight: 600; cursor: pointer;
      padding: 15px 34px; border: 0; border-radius: 14px; text-decoration: none;
      color: var(--text-on-accent);
      background: var(--gradient-cta);
      box-shadow: 0 0 0 1px rgba(0,212,255,.4), 0 12px 40px rgba(0,212,255,0.25);
      transition: transform .2s, box-shadow .2s;
    }
    .cta:hover { transform: translateY(-2px); box-shadow: 0 0 0 1px rgba(0,212,255,.6), 0 16px 50px rgba(0,212,255,0.38); }
    .cta svg { width: 18px; height: 18px; }
    body[data-lang="fa"] .cta svg { transform: scaleX(-1); }

    @media (prefers-reduced-motion: reduce) { #particles { display: none; } }
    @media (max-width: 600px) { .nav-links .hide-mobile { display: none; } }
  </style>
</head>
<body data-lang="fa">
  <canvas id="particles"></canvas>
  <div class="glow glow-1"></div>
  <div class="glow glow-2"></div>
  <div class="glow glow-3"></div>

  <div class="wrap">
    {!hideNav && (
    <nav>
      <a href="/" class="logo">HMR</a>
      <div class="nav-links">
        <a href="/" class="nav-link">خانه</a>
        <a href="/blog" class="nav-link">بلاگ</a>
        <a href="/about" class="nav-link">درباره ما</a>
        <a href="/ai" class="nav-link cta-nav">مشاور هوشمند</a>
      </div>
    </nav>
    )}

    <slot />
  </div>

  <footer>
    <div class="wrap">
      <div class="footer-links">
        <a href="/">خانه</a>
        <a href="/blog">بلاگ</a>
        <a href="/about">درباره ما</a>
        <a href="/contact">ارتباط با ما</a>
        <a href="/privacy">حریم خصوصی</a>
        <a href="/disclaimer">سلب مسئولیت</a>
      </div>
      <div>© ۱۴۰۵ همر — هوش مصنوعی راه. تمامی حقوق محفوظ است.</div>
    </div>
  </footer>

  <script>
    const canvas = document.getElementById('particles') as HTMLCanvasElement;
    if (canvas && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const ctx = canvas.getContext('2d')!;
      let w: number, h: number;
      const COUNT = 55;
      let pts: {x:number;y:number;vx:number;vy:number;r:number}[] = [];
      const resize = () => { w = canvas.width = innerWidth; h = canvas.height = innerHeight; };
      const init = () => { pts = Array.from({length:COUNT},()=>({x:Math.random()*w,y:Math.random()*h,vx:(Math.random()-.5)*.4,vy:(Math.random()-.5)*.4,r:Math.random()*1.5+.6})); };
      const draw = () => {
        ctx.clearRect(0,0,w,h);
        for(const p of pts){
          p.x+=p.vx; p.y+=p.vy;
          if(p.x<0||p.x>w)p.vx*=-1; if(p.y<0||p.y>h)p.vy*=-1;
          ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
          ctx.fillStyle='rgba(0,212,255,.5)'; ctx.fill();
        }
        for(let i=0;i<pts.length;i++) for(let j=i+1;j<pts.length;j++){
          const a=pts[i],b=pts[j],d=Math.hypot(a.x-b.x,a.y-b.y);
          if(d<130){ctx.beginPath();ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);ctx.strokeStyle=`rgba(47,107,255,${.2*(1-d/130)})`;ctx.lineWidth=.6;ctx.stroke();}
        }
        requestAnimationFrame(draw);
      };
      resize(); init(); draw();
      addEventListener('resize',()=>{resize();init();});
    }
  </script>
</body>
</html>
