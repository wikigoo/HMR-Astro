---
import Layout from '../layouts/Layout.astro';
---
<Layout title="همر | هوش مصنوعی موبایل">
  <style>
    .hero { text-align: center; padding: 80px 0 64px; }
    .hero h1 { font-size: clamp(2.3rem,6vw,4rem); line-height:1.08; font-weight:700; margin-bottom:20px; }
    .hero h1 .accent { background: linear-gradient(90deg, var(--cyan), var(--pink)); -webkit-background-clip:text; background-clip:text; color:transparent; }
    .hero p { font-size: clamp(1rem,2.2vw,1.2rem); color: var(--muted); max-width:560px; margin:0 auto 38px; }
    .features { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; padding-bottom:90px; }
    .card .icon { width:52px; height:52px; display:grid; place-items:center; border-radius:13px; margin-bottom:18px; background:rgba(0,212,255,.08); border:1px solid var(--border); }
    .card .icon svg { width:26px; height:26px; stroke:var(--cyan); fill:none; stroke-width:1.7; }
    .card h3 { font-size:1.15rem; margin-bottom:8px; font-weight:600; }
    .card p { color:var(--muted); font-size:.93rem; line-height:1.65; }
    @media(max-width:760px){ .features{grid-template-columns:1fr;} .hero{padding:56px 0 48px;} }
  </style>

  <section class="hero">
    <span class="badge">
      <span class="en">AI Mobile Hardware Advisor</span>
      <span class="fa">مشاور هوشمند سخت‌افزار موبایل</span>
    </span>
    <h1>
      <span class="en">Your Smart <span class="accent">Mobile Advisor</span></span>
      <span class="fa">مشاور هوشمند <span class="accent">موبایل</span> شما</span>
    </h1>
    <p>
      <span class="en">Price it before you buy. Consult before you repair.</span>
      <span class="fa">قبل از خرید، قیمت بگیر. قبل از تعمیر، مشورت کن.</span>
    </p>
    <a class="cta" href="https://hmrbot.com/ai">
      <span class="en">Start Chat</span>
      <span class="fa">شروع گفتگو</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </a>
  </section>

  <section class="features">
    <div class="card">
      <div class="icon"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg></div>
      <h3><span class="en">Second-Hand Inspection</span><span class="fa">بررسی موبایل</span></h3>
      <p><span class="en">Step-by-step diagnostic checklist and USSD test codes to verify any used phone before you pay.</span><span class="fa">چک‌لیست عیب‌یابی گام‌به‌گام و کدهای تست برای بررسی موبایل دست دوم قبل از پرداخت.</span></p>
    </div>
    <div class="card">
      <div class="icon"><svg viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
      <h3><span class="en">Live Market Price</span><span class="fa">قیمت لحظه‌ای بازار</span></h3>
      <p><span class="en">Real-time Toman pricing for new and used devices, sourced directly from the Iranian market.</span><span class="fa">قیمت لحظه‌ای به تومان برای دستگاه‌های نو و دست دوم، مستقیم از بازار ایران.</span></p>
    </div>
    <div class="card">
      <div class="icon"><svg viewBox="0 0 24 24"><path d="M12 2 4 5v6c0 5 3.4 8.6 8 11 4.6-2.4 8-6 8-11V5z"/><path d="m9 12 2 2 4-4"/></svg></div>
      <h3><span class="en">Warranty Verification</span><span class="fa">تشخیص گارانتی اصل</span></h3>
      <p><span class="en">Cross-check warranty cards against the national registry to spot counterfeit guarantees instantly.</span><span class="fa">بررسی کارت گارانتی با سامانه ملی برای تشخیص فوری گارانتی‌های جعلی.</span></p>
    </div>
  </section>
</Layout>