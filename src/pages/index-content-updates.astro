      <linearGradient id="hmrOrbNav" x1="34" y1="40" x2="170" y2="168" gradientUnits="userSpaceOnUse">
        <stop offset="0" stop-color="#5ce1ff"/>
        <stop offset="0.45" stop-color="#2f6bff"/>
        <stop offset="1" stop-color="#6366f1"/>
      </linearGradient>
    </defs>
    <circle cx="100" cy="100" r="64" fill="url(#hmrOrbNav)"/>
    <g transform="rotate(-7 100 87)">
      <ellipse cx="100" cy="87" rx="58" ry="34" fill="none" stroke="#05070f" stroke-width="8.5"/>
