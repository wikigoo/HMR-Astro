---
// ۱. ایمپورت کردن لیوت اصلی سایت جهت حفظ هدر، فوتر و فونت وزیرمتن
// (اگر اسم فایل لیوت اصلی شما در پوشه layouts چیز دیگری است، مسیر زیر را اصلاح کنید)
import Layout from '../layouts/Layout.astro';
---

<Layout title="۴۰۴ - سیگنال گم شده | همر">
  <main class="min-h-[75vh] flex items-center justify-center px-4 py-16 text-slate-100" dir="rtl">
    
    {/* کارت گلس‌مورفیسم مرکزی */}
    <div class="max-w-lg w-full text-center bg-slate-900/50 backdrop-blur-md border border-cyan-500/20 rounded-3xl p-8 md:p-12 shadow-[0_0_50px_-15px_rgba(6,182,212,0.15)] relative overflow-hidden">
      
      {/* هاله نور پس‌زمینه (Glow Effect) */}
      <div class="absolute -top-24 left-1/2 -translate-x-1/2 w-48 h-48 bg-cyan-500/10 rounded-full blur-3xl pointer-events-none"></div>

      {/* عدد ۴۰۴ با گرادینت متالیک */}
      <h1 class="text-7xl md:text-8xl font-black text-transparent bg-clip-text bg-gradient-to-b from-cyan-400 via-slate-200 to-slate-600 tracking-widest mb-4 select-none font-mono">
        404
      </h1>

      <h2 class="text-xl md:text-2xl font-bold text-slate-100 mb-3">
        این سیگنال در فضا گم شده است!
      </h2>
      
      <p class="text-slate-400 text-sm md:text-base leading-relaxed mb-8 max-w-md mx-auto">
        به نظر می‌رسد دستگاه یا صفحه‌ای که به دنبال آن هستید در پایگاه داده‌ی همر ثبت نشده، یا مسیر را اشتباه آمده‌اید.
      </p>

      {/* دکمه‌های اقدام (CTA) */}
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3.5">
        
        {/* دکمه اصلی -> هدایت به چت */}
        <a 
          href="/chat" 
          class="w-full sm:w-auto px-6 py-3 rounded-xl bg-cyan-500 hover:bg-cyan-400 text-slate-950 font-bold text-sm transition-all duration-200 shadow-[0_0_20px_rgba(6,182,212,0.35)] hover:scale-[1.02]"
        >
          شروع مشورت با همر
        </a>

        {/* دکمه دوم -> بازگشت به خانه */}
        <a 
          href="/" 
          class="w-full sm:w-auto px-6 py-3 rounded-xl bg-slate-800/60 hover:bg-slate-700/80 text-cyan-400 border border-cyan-500/30 font-medium text-sm transition-all duration-200"
        >
          بازگشت به پایگاه (خانه)
        </a>

      </div>

    </div>

  </main>
</Layout>