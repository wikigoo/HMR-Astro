---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? true : true;
});

// Sort by pubDate descending
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const pillarColors: Record<string, string> = {
  'راهنمای خرید گوشی نو': 'var(--hmr-cyan)',
  'راهنمای خرید گوشی دست‌دوم و تشخیص تقلب': 'var(--hmr-pink)',
  'عیب‌یابی و تشخیص خرابی سخت‌افزار': 'var(--hmr-violet)',
  'آموزش سخت‌افزار': 'var(--hmr-green, #10b981)',
  'راهنمای لوازم جانبی': 'var(--hmr-amber, #f59e0b)',
};
---

<Layout title="بلاگ همر — مقالات مشاوره موبایل" description="مقالات تخصصی همر در زمینه راهنمای خرید، عیب‌یابی و آموزش سخت‌افزار موبایل">
  <style>
    .blog-hero {
      text-align: center;
      padding: 64px 0 48px;
    }
    .blog-hero h1 {
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      margin-bottom: 12px;
    }
    .blog-hero h1 .accent {
      background: linear-gradient(90deg, var(--hmr-cyan), var(--hmr-pink));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .blog-hero p {
      color: var(--text-muted);
      font-size: 1.05rem;
      max-width: 520px;
      margin: 0 auto;
    }
    .pillar-filters {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: center;
      margin-bottom: 40px;
    }
    .pillar-filters a {
      padding: 6px 16px;
      border-radius: 20px;
      border: 1px solid var(--border-subtle);
      font-size: 0.88rem;
      color: var(--text-muted);
      text-decoration: none;
      transition: all 0.2s;
    }
    .pillar-filters a:hover,
    .pillar-filters a.active {
      border-color: var(--hmr-cyan);
      color: var(--hmr-cyan);
      background: rgba(0, 212, 255, 0.06);
    }
    .post-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 24px;
      padding-bottom: 80px;
    }
    .post-card {
      background: var(--surface-card);
      border: 1px solid var(--border-subtle);
      border-radius: 16px;
      padding: 28px;
      transition: border-color 0.2s, transform 0.15s;
      display: flex;
      flex-direction: column;
    }
    .post-card:hover {
      border-color: var(--hmr-cyan);
      transform: translateY(-2px);
    }
    .post-card .pillar-badge {
      display: inline-block;
      font-size: 0.78rem;
      padding: 3px 10px;
      border-radius: 12px;
      margin-bottom: 14px;
      width: fit-content;
      border: 1px solid;
    }
    .post-card h2 {
      font-size: 1.15rem;
      font-weight: 600;
      line-height: 1.55;
      margin-bottom: 10px;
    }
    .post-card h2 a {
      color: var(--text-body);
      text-decoration: none;
    }
    .post-card h2 a:hover {
      color: var(--hmr-cyan);
    }
    .post-card .summary {
      color: var(--text-muted);
      font-size: 0.9rem;
      line-height: 1.7;
      flex: 1;
      margin-bottom: 16px;
    }
    .post-card .meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.8rem;
      color: var(--text-muted);
      border-top: 1px solid var(--border-subtle);
      padding-top: 14px;
    }
    .post-card .meta .tags {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    .post-card .meta .tag {
      background: rgba(255,255,255,0.04);
      padding: 2px 8px;
      border-radius: 6px;
      font-size: 0.75rem;
    }
    .empty-state {
      text-align: center;
      padding: 80px 20px;
      color: var(--text-muted);
    }
    .empty-state svg {
      width: 64px;
      height: 64px;
      margin-bottom: 20px;
      opacity: 0.4;
    }
    @media (max-width: 760px) {
      .post-grid { grid-template-columns: 1fr; }
      .blog-hero { padding: 40px 0 32px; }
    }
  </style>

  <section class="blog-hero">
    <h1>بلاگ <span class="accent">همر</span></h1>
    <p>مقالات تخصصی مشاوره موبایل — راهنمای خرید، عیب‌یابی و آموزش سخت‌افزار</p>
  </section>

  <div class="pillar-filters">
    <a href="/blog" class="active">همه مقالات</a>
    <a href="/blog/pillar/راهنمای-خرید-گوشی-نو">راهنمای خرید گوشی نو</a>
    <a href="/blog/pillar/راهنمای-خرید-گوشی-دست‌دوم">گوشی دست‌دوم</a>
    <a href="/blog/pillar/عیب‌یابی">عیب‌یابی</a>
    <a href="/blog/pillar/آموزش-سخت‌افزار">آموزش سخت‌افزار</a>
    <a href="/blog/pillar/لوازم-جانبی">لوازم جانبی</a>
  </div>

  {
    posts.length === 0 ? (
      <div class="empty-state">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>
        </svg>
        <p>هنوز مقاله‌ای منتشر نشده است. به‌زودی محتوای تخصصی همر در اینجا قرار می‌گیرد.</p>
      </div>
    ) : (
      <div class="post-grid">
        {posts.map((post) => {
          const pillarColor = pillarColors[post.data.pillar] || 'var(--text-muted)';
          return (
            <article class="post-card">
              <span
                class="pillar-badge"
                style={`color: ${pillarColor}; border-color: ${pillarColor}; background: ${pillarColor}11;`}
              >
                {post.data.pillar}
              </span>
              <h2>
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h2>
              <p class="summary">{post.data.description || post.data.summary}</p>
              <div class="meta">
                <span>{new Date(post.data.pubDate).toLocaleDateString('fa-IR')}</span>
                <div class="tags">
                  {post.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            </article>
          );
        })}
      </div>
    )
  }
</Layout>