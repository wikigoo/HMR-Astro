---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/blog');

const post = await getEntry('blog', slug);
if (!post) return Astro.redirect('/blog');

const { title, pubDate, pillar, tags, summary, source, sourceName, heroImage } = post.data;
const { Content } = await post.render();
---

<Layout title={`${title} — بلاگ همر`} description={summary}>
  <style>
    .article-container {
      max-width: 760px;
      margin: 0 auto;
      padding: 48px 20px 80px;
    }
    .article-header {
      margin-bottom: 36px;
    }
    .article-header .pillar-badge {
      display: inline-block;
      font-size: 0.82rem;
      padding: 4px 14px;
      border-radius: 14px;
      margin-bottom: 16px;
      border: 1px solid var(--hmr-cyan);
      color: var(--hmr-cyan);
      background: rgba(0, 212, 255, 0.06);
    }
    .article-header h1 {
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      font-weight: 700;
      line-height: 1.45;
      margin-bottom: 14px;
      color: var(--text-body);
    }
    .article-header .meta {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      font-size: 0.88rem;
      color: var(--text-muted);
      align-items: center;
    }
    .article-header .meta .tags {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    .article-header .meta .tag {
      background: rgba(255,255,255,0.04);
      padding: 2px 10px;
      border-radius: 8px;
      font-size: 0.78rem;
      border: 1px solid var(--border-subtle);
    }
    .hero-image {
      width: 100%; aspect-ratio: 16/9; object-fit: cover;
      border-radius: 16px; margin-bottom: 32px;
      border: 1px solid var(--border-subtle);
    }
    .article-body {
      font-size: 1.05rem;
      line-height: 2;
      color: var(--text-body);
    }
    .article-body :global(h2) {
      font-size: 1.4rem;
      font-weight: 600;
      margin: 36px 0 14px;
      color: var(--text-body);
    }
    .article-body :global(h3) {
      font-size: 1.15rem;
      font-weight: 600;
      margin: 28px 0 10px;
    }
    .article-body :global(p) {
      margin-bottom: 16px;
    }
    .article-body :global(ul), .article-body :global(ol) {
      margin-bottom: 16px;
      padding-right: 24px;
    }
    .article-body :global(li) {
      margin-bottom: 8px;
    }
    .article-body :global(a) {
      color: var(--hmr-cyan);
      text-decoration: underline;
    }
    .article-body :global(blockquote) {
      border-right: 3px solid var(--hmr-cyan);
      padding: 12px 20px;
      margin: 20px 0;
      background: rgba(0, 212, 255, 0.04);
      border-radius: 0 8px 8px 0;
      color: var(--text-muted);
    }
    .article-body :global(hr) {
      border: none;
      border-top: 1px solid var(--border-subtle);
      margin: 32px 0;
    }
    .article-body :global(strong) {
      color: var(--text-body);
      font-weight: 600;
    }
    .article-body :global(code) {
      background: rgba(255,255,255,0.06);
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 0.9em;
    }
    .source-link {
      margin-top: 48px;
      padding: 16px 20px;
      background: var(--surface-card);
      border: 1px solid var(--border-subtle);
      border-radius: 12px;
      font-size: 0.85rem;
      color: var(--text-muted);
    }
    .source-link a {
      color: var(--hmr-cyan);
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.9rem;
      margin-bottom: 24px;
      transition: color 0.2s;
    }
    .back-link:hover {
      color: var(--hmr-cyan);
    }
    @media (max-width: 760px) {
      .article-container { padding: 32px 16px 60px; }
    }
  </style>

  <article class="article-container">
    <a href="/blog" class="back-link">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5m7-7-7 7 7 7"/>
      </svg>
      بازگشت به بلاگ
    </a>

    <header class="article-header">
      <span class="pillar-badge">{pillar}</span>
      <h1>{title}</h1>
      <div class="meta">
        <span>{new Date(pubDate).toLocaleDateString('fa-IR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        <div class="tags">
          {tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
      </div>
    </header>

    {heroImage && heroImage !== '' && (
      <img class="hero-image" src={heroImage} alt={title} loading="lazy" />
    )}

    <div class="article-body">
      <Content />
    </div>

    {source && (
      <div class="source-link">
        📰 منبع اصلی: <a href={source} target="_blank" rel="noopener noreferrer">{sourceName || source}</a>
      </div>
    )}
  </article>
</Layout>
