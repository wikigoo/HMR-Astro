---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';

const chatflowId = (env as any).FLOWISE_CHATFLOW_ID ?? '463b566b-f0f1-44d8-b498-3827c188783a';
const apiKeyConfigured = Boolean((env as any).FLOWISE_API_KEY);
---
<AdminLayout title="چت‌بات">
  <h1>چت‌بات</h1>
  <p style="color:var(--text-secondary); margin-bottom:24px;">
    این صفحه فقط پیکربندی غیرحساس فعلی را نشان می‌دهد. برای تغییر پرامپت/فلو، مستقیماً به Flowise
    (<code>srv.hmrbot.com</code>) مراجعه کن — مدیریت فلو از این پنل پشتیبانی نمی‌شود.
  </p>

  <div class="admin-card">
    <table>
      <tbody>
        <tr><th>آدرس بک‌اند</th><td>srv.hmrbot.com</td></tr>
        <tr><th>Chatflow ID فعال</th><td>{chatflowId}</td></tr>
        <tr><th>API Key</th><td>{apiKeyConfigured ? '✅ تنظیم شده' : '⚠️ تنظیم نشده'}</td></tr>
      </tbody>
    </table>
  </div>

  <div class="admin-card">
    <h2 style="margin-bottom:10px;">بررسی سریع</h2>
    <p><a class="link" href="https://hmrbot.com/api/health" target="_blank" rel="noopener">/api/health ←</a></p>
  </div>
</AdminLayout>
