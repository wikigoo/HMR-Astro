---
// src/pages/ai.astro
// HMR — full-page AI advisor at /ai.
// Custom chat shell (sidebar · centered orb · glass composer) wired directly
// to the Flowise prediction API with token streaming + session memory.
// CORS: in Flowise, set Allowed Origins = https://hmrbot.com for this chatflow.
const CHATFLOW_ID = import.meta.env.FLOWISE_CHATFLOW_ID ?? '843b252b-6ed0-4064-96cd-cb78367bd7b3';
const FLOWISE_API = 'https://srv.hmrbot.com';
const FLOWISE_API_KEY = import.meta.env.FLOWISE_API_KEY;
// Improved orb lives in public/assets/hmr-logo.svg (copy it from the design system).
const LOGO = '/assets/hmr-logo.svg';
---
<!doctype html>
<html lang="fa" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>HMR — مشاور هوشمند موبایل</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" />
  <style>
    @font-face {
      font-family: 'Vazirmatn';
      src: url('/fonts/Vazirmatn-VariableFont_wght.ttf') format('truetype');
      font-weight: 100 900; font-display: swap;
    }

    /* ── HMR design tokens ──────────────────────────────────── */
    :root {
      --surface-page:   #05070f;
      --surface-card:   rgba(18,26,48,0.55);
      --surface-card-2: rgba(20,30,56,0.72);
      --surface-well:   rgba(0,212,255,0.08);
      --accent:   #00d4ff;
      --accent-2: #2f6bff;
      --accent-3: #6366f1;
      --gradient-cta: linear-gradient(100deg,#00d4ff 0%,#3b82f6 100%);
      --gradient-text: linear-gradient(95deg,#5ce1ff 0%,#3b82f6 60%,#6366f1 100%);
      --text-body:      #eaf2ff;
      --text-secondary: #b9c6e4;
      --text-muted:     #8a96b3;
      --text-dim:       #56627f;
      --text-on-accent: #05070f;
      --border-subtle:  rgba(0,212,255,0.18);
      --border-glow:    rgba(0,212,255,0.45);
      --glow-cyan:   #00d4ff;
      --glow-indigo: #6366f1;
      --blur-glass:    blur(14px);
      --blur-glass-sm: blur(10px);
      --blur-glow:     blur(120px);
      --font-fa: 'Vazirmatn', system-ui, sans-serif;
      --radius-pill: 999px; --radius-xl: 18px;
      --ease-out: cubic-bezier(.22,1,.36,1);
      --dur-fast: .2s; --dur-med: .25s;
    }

    *,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }
    html, body { height:100%; overflow:hidden; }
    body {
      background: var(--surface-page); color: var(--text-body);
      font-family: var(--font-fa); direction: rtl;
      -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility;
    }

    /* ── Ambient background ─────────────────────────────────── */
    #particles { position:fixed; inset:0; z-index:0; pointer-events:none; }
    .glow { position:fixed; border-radius:50%; filter:var(--blur-glow); pointer-events:none; z-index:0; }
    .glow-1 { width:520px; height:520px; background:var(--glow-cyan);   top:-160px; left:-120px; opacity:.22; }
    .glow-2 { width:460px; height:460px; background:var(--glow-indigo); bottom:-180px; right:200px; opacity:.20; }

    .app { position:relative; z-index:2; height:100vh; display:flex; }

    /* ── Sidebar (right, RTL) ───────────────────────────────── */
    .sidebar {
      width:290px; flex-shrink:0; display:flex; flex-direction:column;
      border-inline-end:1px solid var(--border-subtle);
      background:rgba(8,12,24,0.5);
      -webkit-backdrop-filter:var(--blur-glass); backdrop-filter:var(--blur-glass);
      transition:width var(--dur-med) var(--ease-out), opacity var(--dur-med) var(--ease-out);
    }
    .app.sb-collapsed .sidebar { width:0; opacity:0; pointer-events:none; overflow:hidden; }

    .sb-top { padding:18px 18px 14px; }
    .sb-brand-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:18px; }
    .sb-wordmark {
      font-family:'Space Grotesk', system-ui, sans-serif;
      font-weight:700; font-size:1.35rem; line-height:1; letter-spacing:0.04em;
      background:var(--gradient-text); -webkit-background-clip:text; background-clip:text;
      -webkit-text-fill-color:transparent; color:transparent; padding-bottom:.04em;
    }
    .sb-tools { display:flex; align-items:center; gap:6px; }
    .icon-btn {
      width:34px; height:34px; border-radius:9px; display:flex; align-items:center; justify-content:center;
      background:transparent; border:1px solid transparent; color:var(--text-muted); cursor:pointer;
      transition:color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out);
    }
    .icon-btn:hover { color:var(--text-body); background:var(--surface-well); border-color:var(--border-subtle); }
    .icon-btn svg { width:18px; height:18px; }

    .new-chat {
      width:100%; display:flex; align-items:center; justify-content:space-between; gap:10px;
      padding:12px 16px; border-radius:var(--radius-pill);
      background:var(--surface-card); border:1px solid var(--border-subtle); color:var(--text-body);
      cursor:pointer; font-family:var(--font-fa); font-weight:500; font-size:.88rem;
      -webkit-backdrop-filter:var(--blur-glass-sm); backdrop-filter:var(--blur-glass-sm);
      transition:border-color var(--dur-med) var(--ease-out), transform var(--dur-fast) var(--ease-out), box-shadow var(--dur-med) var(--ease-out);
    }
    .new-chat:hover { border-color:var(--border-glow); box-shadow:0 0 0 1px var(--border-glow), 0 8px 26px rgba(0,212,255,.10); transform:translateY(-1px); }
    .new-chat:active { transform:translateY(0); }
    .new-chat svg { width:18px; height:18px; color:var(--accent); }

    .sb-divider { height:1px; background:var(--border-subtle); margin:6px 18px; }
    .sb-hist { flex:1; min-height:0; display:flex; flex-direction:column; padding:6px 10px; }
    .sb-hist-label { padding:10px 8px 8px; font-weight:500; font-size:.9rem; color:var(--text-secondary); }
    .hist-list { flex:1; min-height:0; overflow-y:auto; display:flex; flex-direction:column; gap:4px; }
    .hist-empty { padding:22px 10px; color:var(--text-muted); font-size:.85rem; line-height:1.8; text-align:center; }
    .hist-item {
      display:flex; align-items:center; gap:9px; padding:10px 12px; border-radius:10px; cursor:pointer;
      color:var(--text-secondary); font-size:.84rem; border:1px solid transparent;
      white-space:nowrap; overflow:hidden;
      transition:background var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out);
    }
    .hist-item:hover, .hist-item.active { background:var(--surface-well); color:var(--text-body); border-color:var(--border-subtle); }
    .hist-item svg { width:15px; height:15px; flex-shrink:0; color:var(--text-muted); }
    .hist-item span { overflow:hidden; text-overflow:ellipsis; }

    .sb-foot { padding:12px 14px; border-top:1px solid var(--border-subtle); }
    .login {
      width:100%; display:flex; align-items:center; gap:11px; padding:9px 12px; border-radius:var(--radius-pill);
      background:transparent; border:1px solid var(--border-subtle); color:var(--text-body); cursor:pointer;
      font-family:var(--font-fa); font-weight:500; font-size:.86rem;
      transition:border-color var(--dur-med) var(--ease-out), background var(--dur-fast) var(--ease-out);
    }
    .login:hover { border-color:var(--border-glow); background:var(--surface-well); }
    .avatar {
      width:30px; height:30px; border-radius:50%; flex:0 0 30px; background:var(--gradient-cta);
      box-shadow:0 0 0 1px rgba(255,255,255,.12) inset, 0 2px 10px rgba(0,212,255,.35);
    }
    .login > span:last-child { flex:1; text-align:start; }

    /* ── Main ───────────────────────────────────────────────── */
    .main { flex:1; min-width:0; display:flex; flex-direction:column; position:relative; }
    .floating-open { position:absolute; top:16px; inset-inline-start:16px; z-index:5; display:none; }
    .app.sb-collapsed .floating-open { display:flex; }

    .stage { flex:1; min-height:0; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:24px; }

    .hero { width:100%; max-width:720px; display:flex; flex-direction:column; align-items:center; }
    .hero-orb {
      width:96px; height:96px; margin-bottom:22px;
      animation:orb-float 5s var(--ease-out) infinite, orb-glow 3s ease-in-out infinite;
    }
    @keyframes orb-float { 0%,100% { transform:translateY(0); } 50% { transform:translateY(-7px); } }
    @keyframes orb-glow {
      0%,100% { filter:drop-shadow(0 6px 14px rgba(0,212,255,.30)); }
      50%     { filter:drop-shadow(0 8px 26px rgba(0,212,255,.62)); }
    }
    .hero-title { font-weight:500; font-size:clamp(1.15rem,2.4vw,1.5rem); line-height:1.4; text-align:center; margin-bottom:0; color:rgba(234,242,255,0.78); letter-spacing:0.01em; text-shadow:0 0 20px rgba(0,212,255,0.35); }
    .hero-sub { color:var(--text-secondary); text-align:center; font-size:1rem; line-height:1.9; max-width:520px; margin-bottom:30px; }

    .composer {
      width:100%; max-width:720px; margin:0 auto; display:flex; align-items:flex-end; gap:10px; padding:14px 16px; border-radius:24px;
      background:var(--surface-card-2); border:1px solid var(--border-subtle);
      -webkit-backdrop-filter:var(--blur-glass); backdrop-filter:var(--blur-glass);
      box-shadow:0 18px 50px rgba(0,0,0,.45), inset 0 1px 0 rgba(255,255,255,.04);
      transition:border-color var(--dur-med) var(--ease-out), box-shadow var(--dur-med) var(--ease-out);
    }
    .composer:focus-within { border-color:var(--border-glow); box-shadow:0 18px 50px rgba(0,0,0,.45), 0 0 0 1px var(--border-glow), 0 0 40px rgba(0,212,255,.14); }
    .composer textarea {
      flex:1; resize:none; border:0; outline:0; background:transparent; color:var(--text-body);
      font-family:var(--font-fa); font-size:1.02rem; line-height:1.7; max-height:180px; padding:8px 4px;
    }
    .composer textarea::placeholder { color:var(--text-muted); }
    .send-btn {
      width:44px; height:44px; border-radius:14px; flex-shrink:0; display:flex; align-items:center; justify-content:center;
      background:var(--gradient-cta); border:0; cursor:pointer; color:var(--text-on-accent);
      box-shadow:0 4px 18px rgba(0,212,255,.35);
      transition:transform var(--dur-fast) var(--ease-out), filter var(--dur-fast) var(--ease-out), opacity var(--dur-fast) var(--ease-out);
    }
    .send-btn:hover { transform:translateY(-2px); filter:brightness(1.08); }
    .send-btn:active { transform:translateY(0); }
    .send-btn:disabled { opacity:.45; cursor:not-allowed; transform:none; box-shadow:none; }
    .send-btn svg { width:20px; height:20px; }

    .chips { display:flex; flex-wrap:wrap; gap:10px; justify-content:center; margin-top:20px; max-width:720px; }
    .chip {
      padding:9px 15px; border-radius:var(--radius-pill); background:var(--surface-card); border:1px solid var(--border-subtle);
      color:var(--text-secondary); font-family:var(--font-fa); font-size:.9rem; cursor:pointer;
      -webkit-backdrop-filter:var(--blur-glass-sm); backdrop-filter:var(--blur-glass-sm);
      transition:border-color var(--dur-med) var(--ease-out), color var(--dur-fast) var(--ease-out), transform var(--dur-fast) var(--ease-out);
    }
    .chip:hover { border-color:var(--border-glow); color:var(--text-body); transform:translateY(-2px); }

    /* ── Conversation ───────────────────────────────────────── */
    .main.has-chat .stage { justify-content:flex-start; align-items:stretch; padding:0; }
    .main.has-chat .hero { display:none; }
    .convo-wrap { display:none; flex:1; min-height:0; flex-direction:column; }
    .main.has-chat .convo-wrap { display:flex; }
    .messages { flex:1; min-height:0; overflow-y:auto; padding:28px 0 16px; }
    .messages-inner { max-width:760px; margin:0 auto; padding:0 24px; display:flex; flex-direction:column; gap:18px; }

    .msg { display:flex; gap:12px; align-items:flex-start; }
    .msg.user { flex-direction:row-reverse; }
    .msg-ava {
      width:34px; height:34px; border-radius:10px; flex-shrink:0; display:flex; align-items:center; justify-content:center;
      background:var(--surface-well); border:1px solid var(--border-subtle); overflow:hidden;
    }
    .msg-ava img { width:26px; height:26px; }
    .msg.user .msg-ava { background:var(--gradient-cta); border:0; }
    .bubble { padding:13px 16px; border-radius:16px; line-height:1.85; font-size:1rem; max-width:80%; word-break:break-word; }
    .msg.assistant .bubble { background:var(--surface-card); border:1px solid var(--border-subtle); color:var(--text-body); border-top-right-radius:6px; }
    .msg.user .bubble { background:var(--accent-2); color:#fff; border-top-left-radius:6px; white-space:pre-wrap; }
    /* markdown-ish output from the model */
    .msg.assistant .bubble p { margin:0 0 8px; } .msg.assistant .bubble p:last-child { margin:0; }
    .msg.assistant .bubble ul, .msg.assistant .bubble ol { margin:6px 1.2em 8px 0; padding:0; }
    .msg.assistant .bubble a { color:var(--accent); }
    .msg.assistant .bubble strong { color:#fff; }
    .typing { display:inline-flex; gap:5px; padding:4px 2px; }
    .typing i { width:7px; height:7px; border-radius:50%; background:var(--accent); opacity:.5; animation:blink 1.2s infinite; }
    .typing i:nth-child(2) { animation-delay:.2s; } .typing i:nth-child(3) { animation-delay:.4s; }
    @keyframes blink { 0%,60%,100% { opacity:.3; transform:translateY(0); } 30% { opacity:1; transform:translateY(-3px); } }

    .dock { flex-shrink:0; padding:12px 24px 16px; }
    .main.has-chat .composer { box-shadow:0 10px 36px rgba(0,0,0,.4); }

    .foot { flex-shrink:0; padding:14px 24px 20px; text-align:center; }
    .foot-links { display:inline-flex; align-items:center; gap:14px; flex-wrap:wrap; justify-content:center; }
    .foot-links a { color:var(--text-secondary); text-decoration:none; font-size:.88rem; transition:color var(--dur-fast) var(--ease-out); }
    .foot-links a:hover { color:var(--accent); }
    .foot-sep { color:var(--text-dim); }
    .main.has-chat .foot { display:none; }

    @media (max-width:720px) {
      .sidebar { position:fixed; inset-inline-end:0; top:0; height:100vh; z-index:30; box-shadow:-20px 0 60px rgba(0,0,0,.6); }
    }
    @media (prefers-reduced-motion:reduce) {
      #particles { display:none; }
      .hero-orb { animation:none; filter:drop-shadow(0 0 12px rgba(0,212,255,.4)); }
      * { animation-duration:.001ms !important; transition-duration:.001ms !important; }
    }
  </style>
</head>
<body>
  <canvas id="particles"></canvas>
  <div class="glow glow-1"></div>
  <div class="glow glow-2"></div>

  <div class="app" id="app">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sb-top">
        <div class="sb-brand-row">
          <div class="sb-wordmark">HMR</div>
          <div class="sb-tools">
            <button class="icon-btn" aria-label="جستجو" title="جستجو">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
            </button>
            <button class="icon-btn" id="toggle-sb" aria-label="جمع کردن نوار کناری" title="نوار کناری">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M9 4v16"></path></svg>
            </button>
          </div>
        </div>
        <button class="new-chat" id="new-chat">
          <span>گفتگوی جدید</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"></path></svg>
        </button>
      </div>

      <div class="sb-divider"></div>

      <div class="sb-hist">
        <div class="sb-hist-label">تاریخچه گفتگو</div>
        <div class="hist-list" id="hist-list">
          <div class="hist-empty">هنوز گفتگویی نداری.<br/>برای شروع سؤالت را بپرس.</div>
        </div>
      </div>

      <div class="sb-foot">
        <button class="login">
          <span class="avatar"></span>
          <span>ورود</span>
        </button>
      </div>
    </aside>

    <!-- Main -->
    <main class="main" id="main">
      <button class="icon-btn floating-open" id="open-sb" aria-label="باز کردن نوار کناری" title="نوار کناری">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"></rect><path d="M9 4v16"></path></svg>
      </button>

      <div class="stage">
        <div class="hero" id="hero">
          <img class="hero-orb" src={LOGO} alt="HMR" />
          <h1 class="hero-title">امروز چطور می‌تونم کمکت کنم؟</h1>
        </div>
        <div class="convo-wrap">
          <div class="messages" id="messages"><div class="messages-inner" id="messages-inner"></div></div>
        </div>
      </div>

      <div class="dock" id="dock">
        <div class="composer">
          <textarea id="input" rows="1" placeholder="سؤالت درباره‌ی هر گوشی‌ای رو بپرس…"></textarea>
          <button class="send-btn" id="send" aria-label="ارسال" disabled>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"></path></svg>
          </button>
        </div>
      </div>

      <footer class="foot">
        <nav class="foot-links">
          <a href="/privacy">حریم خصوصی</a>
          <span class="foot-sep">|</span>
          <a href="/about">ارتباط با ما</a>
          <span class="foot-sep">|</span>
          <a href="/contact">تماس با ما</a>
        </nav>
      </footer>
    </main>
  </div>

  <!-- Neural particle field -->
  <script is:inline>
    (function () {
      var c = document.getElementById('particles'); if (!c) return;
      var ctx = c.getContext('2d'), nodes = [], W, H,
          DPR = Math.min(window.devicePixelRatio || 1, 2), LINK = 150,
          reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      function resize() {
        W = c.clientWidth = window.innerWidth; H = c.clientHeight = window.innerHeight;
        c.width = W * DPR; c.height = H * DPR; ctx.setTransform(DPR,0,0,DPR,0,0);
        var n = Math.round(Math.min(90, (W*H)/16000)); nodes = [];
        for (var i=0;i<n;i++) nodes.push({ x:Math.random()*W, y:Math.random()*H,
          vx:(Math.random()-.5)*.32, vy:(Math.random()-.5)*.32, r:Math.random()*1.6+.8, pulse:Math.random()*Math.PI*2 });
      }
      function draw() {
        ctx.clearRect(0,0,W,H);
        for (var i=0;i<nodes.length;i++) { var a=nodes[i];
          if (!reduce) { a.x+=a.vx; a.y+=a.vy; a.pulse+=.02; if(a.x<0||a.x>W)a.vx*=-1; if(a.y<0||a.y>H)a.vy*=-1; }
          for (var j=i+1;j<nodes.length;j++) { var b=nodes[j], dx=a.x-b.x, dy=a.y-b.y, d=Math.sqrt(dx*dx+dy*dy);
            if (d<LINK) { ctx.strokeStyle='rgba(0,212,255,'+((1-d/LINK)*.5).toFixed(3)+')'; ctx.lineWidth=.7;
              ctx.beginPath(); ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y); ctx.stroke(); } } }
        for (var k=0;k<nodes.length;k++) { var node=nodes[k], glow=.55+.45*Math.sin(node.pulse);
          ctx.beginPath(); ctx.arc(node.x,node.y,node.r,0,Math.PI*2);
          ctx.fillStyle='rgba(92,225,255,'+(.35+glow*.45).toFixed(3)+')';
          ctx.shadowColor='rgba(0,212,255,.8)'; ctx.shadowBlur=6; ctx.fill(); ctx.shadowBlur=0; }
        if (!reduce) requestAnimationFrame(draw);
      }
      window.addEventListener('resize', resize); resize(); draw();
    })();
  </script>

  <!-- Chat logic — direct Flowise prediction API with token streaming -->
  <script is:inline define:vars={{ CHATFLOW_ID, FLOWISE_API, FLOWISE_API_KEY, LOGO }}>
    (function () {
      const app = document.getElementById('app');
      const main = document.getElementById('main');
      const input = document.getElementById('input');
      const sendBtn = document.getElementById('send');
      const messagesInner = document.getElementById('messages-inner');
      const messages = document.getElementById('messages');
      const dock = document.getElementById('dock');
      const stage = document.querySelector('.stage');
      const histList = document.getElementById('hist-list');

      // Stable per-browser session so the bot keeps conversational memory.
      let sessionId = localStorage.getItem('hmr-session');
      if (!sessionId) { sessionId = 'web-' + Math.random().toString(36).slice(2) + Date.now().toString(36); localStorage.setItem('hmr-session', sessionId); }
      let busy = false, historyAdded = false;

      document.getElementById('toggle-sb').addEventListener('click', () => app.classList.add('sb-collapsed'));
      document.getElementById('open-sb').addEventListener('click', () => app.classList.remove('sb-collapsed'));

      function autosize() {
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 180) + 'px';
        sendBtn.disabled = busy || input.value.trim().length === 0;
      }
      input.addEventListener('input', autosize);
      input.addEventListener('keydown', (e) => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); } });
      sendBtn.addEventListener('click', send);

      document.getElementById('new-chat').addEventListener('click', () => {
        if (busy) return;
        messagesInner.innerHTML = '';
        main.classList.remove('has-chat');
        stage.querySelector('.hero').after(dock);
        // fresh memory thread
        sessionId = 'web-' + Math.random().toString(36).slice(2) + Date.now().toString(36);
        localStorage.setItem('hmr-session', sessionId);
        historyAdded = false;
        input.value = ''; autosize(); input.focus();
      });

      function enterChatMode() {
        if (main.classList.contains('has-chat')) return;
        main.classList.add('has-chat');
        main.insertBefore(dock, document.querySelector('.foot'));
      }

      function el(role) {
        const wrap = document.createElement('div');
        wrap.className = 'msg ' + role;
        const ava = document.createElement('div'); ava.className = 'msg-ava';
        if (role === 'assistant') ava.innerHTML = '<img src="' + LOGO + '" alt="HMR" />';
        const bubble = document.createElement('div'); bubble.className = 'bubble';
        wrap.appendChild(ava); wrap.appendChild(bubble);
        messagesInner.appendChild(wrap);
        messages.scrollTop = messages.scrollHeight;
        return bubble;
      }

      // Minimal, safe markdown → HTML (bold, lists, links, line breaks).
      function esc(s){ return s.replace(/[&<>]/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;' }[c])); }
      function md(text) {
        let s = esc(text)
          .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
          .replace(/\[([^\]]+)\]\((https?:[^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
        const lines = s.split('\n'); let out = '', inList = false;
        for (const ln of lines) {
          if (/^\s*[-*]\s+/.test(ln)) { if (!inList){ out+='<ul>'; inList=true; } out += '<li>' + ln.replace(/^\s*[-*]\s+/, '') + '</li>'; }
          else { if (inList){ out+='</ul>'; inList=false; } if (ln.trim()) out += '<p>' + ln + '</p>'; }
        }
        if (inList) out += '</ul>';
        return out;
      }

      async function send() {
        const text = input.value.trim();
        if (!text || busy) return;
        busy = true;
        enterChatMode();

        const u = el('user'); u.textContent = text;
        input.value = ''; autosize(); sendBtn.disabled = true;
        if (!historyAdded) addHistory(text);

        const b = el('assistant');
        b.innerHTML = '<span class="typing"><i></i><i></i><i></i></span>';
        let acc = '';

        try {
          const res = await fetch(FLOWISE_API + '/api/v1/prediction/' + CHATFLOW_ID, {
            method: 'POST', headers: { 'Content-Type': 'application/json', ...(FLOWISE_API_KEY ? { 'Authorization': 'Bearer ' + FLOWISE_API_KEY } : {}) },
            body: JSON.stringify({ question: text, streaming: true, chatId: sessionId, overrideConfig: { sessionId } })
          });

          const ct = res.headers.get('content-type') || '';
          if (ct.includes('text/event-stream') && res.body) {
            const reader = res.body.getReader(); const dec = new TextDecoder(); let buf = '';
            for (;;) {
              const { value, done } = await reader.read(); if (done) break;
              buf += dec.decode(value, { stream: true });
              const parts = buf.split('\n\n'); buf = parts.pop();
              for (const part of parts) {
                const line = part.split('\n').find(l => l.startsWith('data:'));
                if (!line) continue;
                const payload = line.slice(5).trim();
                if (payload === '[DONE]') continue;
                try {
                  const ev = JSON.parse(payload);
                  if (ev.event === 'token' && ev.data) { acc += ev.data; b.innerHTML = md(acc); messages.scrollTop = messages.scrollHeight; }
                  else if (ev.event === 'error') { throw new Error(ev.data || 'stream error'); }
                } catch (_) { /* ignore non-JSON keepalives */ }
              }
            }
            if (!acc) { b.innerHTML = md('پاسخی دریافت نشد. لطفاً دوباره تلاش کن.'); }
          } else {
            const data = await res.json();
            acc = data.text || data.answer || (typeof data === 'string' ? data : '') || 'پاسخی دریافت نشد.';
            b.innerHTML = md(acc);
          }
        } catch (err) {
          b.innerHTML = md('در حال حاضر به مشکل برخوردم. لطفاً دوباره تلاش کن.');
        } finally {
          busy = false; autosize(); input.focus();
          messages.scrollTop = messages.scrollHeight;
        }
      }

      function addHistory(title) {
        if (histList.querySelector('.hist-empty')) histList.innerHTML = '';
        const item = document.createElement('div');
        item.className = 'hist-item active';
        item.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg><span></span>';
        item.querySelector('span').textContent = title;
        histList.prepend(item);
        historyAdded = true;
      }

      autosize(); input.focus();
    })();
  </script>
</body>
</html>

