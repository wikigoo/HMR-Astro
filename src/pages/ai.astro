---
// src/pages/ai.astro
// HMR — full-page AI chat at /ai, powered by the official Flowise embed widget.
// CORS: in Flowise, set Allowed Origins = https://hmrbot.com for this chatflow.
const CHATFLOW_ID = import.meta.env.FLOWISE_CHATFLOW_ID ?? '843b252b-6ed0-4064-96cd-cb78367bd7b3';
const FLOWISE_API = 'http://91.107.159.48';
---
<!doctype html>
<html lang="fa" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>HMR — مشاور هوشمند موبایل</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" />
  <style>
    @font-face {
      font-family: 'Vazirmatn';
      src: url('/fonts/Vazirmatn-VariableFont_wght.ttf') format('truetype');
      font-weight: 100 900;
      font-display: swap;
    }

    /* ── Design Tokens (HMR Design System) ────────────────────── */
    :root {
      --surface-page:   #05070f;
      --surface-card:   rgba(18,26,48,0.55);
      --surface-card-2: rgba(14,20,38,0.65);
      --hmr-cyan:    #00d4ff;
      --hmr-blue:    #2f6bff;
      --hmr-indigo:  #6366f1;
      --text-body:       #eaf2ff;
      --text-secondary:  #b9c6e4;
      --text-muted:      #8a96b3;
      --border-subtle:   rgba(0,212,255,0.12);
      --border-glow:     rgba(0,212,255,0.45);
      --blur-glass-sm:   blur(10px);
      --blur-glow:       blur(120px);
      --glow-opacity:    0.30;
      --font-en: 'Space Grotesk', system-ui, sans-serif;
      --font-fa: 'Vazirmatn', system-ui, sans-serif;
      --radius-pill: 999px;
      --ease-out: cubic-bezier(.22,1,.36,1);
      --dur-med:  .25s;
    }

    /* ── Reset ─────────────────────────────────────────────────── */
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html, body { height:100%; overflow:hidden; }
    body {
      background: var(--surface-page);
      color: var(--text-body);
      font-family: var(--font-fa);   /* Persian by default */
      direction: rtl;
      -webkit-font-smoothing: antialiased;
    }

    /* ── Background ─────────────────────────────────────────────── */
    #particles { position:fixed; inset:0; z-index:0; pointer-events:none; }
    .glow {
      position:fixed; border-radius:50%;
      filter:var(--blur-glow); pointer-events:none; z-index:0;
      opacity:var(--glow-opacity);
    }
    .glow-1 { width:460px; height:460px; background:#00d4ff; top:-120px; left:-100px; }
    .glow-2 { width:420px; height:420px; background:#6366f1; bottom:-140px; right:-120px; }

    /* ── Layout ─────────────────────────────────────────────────── */
    #chat-root {
      position:relative; z-index:2;
      height:100vh;
      display:flex; flex-direction:column;
      max-width:760px;
      margin:0 auto;
      padding:0 16px 16px;
    }

    /* ── Header ─────────────────────────────────────────────────── */
    .chat-header {
      display:flex; align-items:center; gap:12px;
      padding:12px 4px 14px;
      border-bottom:1px solid var(--border-subtle);
      flex-shrink:0;
    }
    .back-btn {
      background:var(--surface-card);
      border:1px solid var(--border-subtle);
      color:var(--text-body);
      width:38px; height:38px;
      border-radius:50%;
      cursor:pointer;
      display:flex; align-items:center; justify-content:center;
      font-size:18px;
      backdrop-filter:var(--blur-glass-sm);
      -webkit-backdrop-filter:var(--blur-glass-sm);
      transition:border-color var(--dur-med) var(--ease-out);
      text-decoration:none; flex-shrink:0;
    }
    .back-btn:hover { border-color:var(--border-glow); }

    /* ── Animated logo (gentle motion + breathing glow) ─────────── */
    .header-logo {
      width:36px; height:36px; flex-shrink:0;
      animation: logo-float 4s var(--ease-out) infinite,
                 logo-glow  2.6s ease-in-out infinite;
    }
    @keyframes logo-float {
      0%,100% { transform: translateY(0); }
      50%     { transform: translateY(-4px); }
    }
    @keyframes logo-glow {
      0%,100% { filter: drop-shadow(0 0 5px rgba(0,212,255,.25)); }
      50%     { filter: drop-shadow(0 0 16px rgba(0,212,255,.75)); }
    }
    @media (prefers-reduced-motion: reduce) {
      .header-logo { animation: none; filter: drop-shadow(0 0 8px rgba(0,212,255,.4)); }
    }

    .header-info { flex:1; min-width:0; }
    .header-name {
      font-family:var(--font-en);
      font-weight:700; font-size:1rem;
      color:var(--text-body); line-height:1.1;
    }
    .header-sub {
      font-family:var(--font-fa);
      font-size:.80rem;
      color:var(--text-muted); line-height:1.3;
    }

    /* ── Flowise widget container ───────────────────────────────── */
    #chat-window {
      flex:1; min-height:0;
      margin-top:12px;
      border:1px solid var(--border-subtle);
      border-radius:16px;
      overflow:hidden;
      backdrop-filter:var(--blur-glass-sm);
      -webkit-backdrop-filter:var(--blur-glass-sm);
    }
    flowise-fullchatbot { display:block; height:100%; width:100%; }
  </style>
</head>
<body>
  <!-- Background -->
  <canvas id="particles"></canvas>
  <div class="glow glow-1"></div>
  <div class="glow glow-2"></div>

  <div id="chat-root">
    <!-- Header: back + animated logo + name. Green "online" badge removed. -->
    <header class="chat-header">
      <a href="/" class="back-btn" aria-label="Back">→</a>
      <img class="header-logo" src="/logo.svg" alt="HMR" />
      <div class="header-info">
        <div class="header-name">HMR</div>
        <div class="header-sub">مشاور هوشمند موبایل</div>
      </div>
    </header>

    <!-- Flowise full chatbot -->
    <div id="chat-window">
      <flowise-fullchatbot></flowise-fullchatbot>
    </div>
  </div>

  <!-- Flowise embed -->
  <script type="module" is:inline define:vars={{ CHATFLOW_ID, FLOWISE_API }}>
    import Chatbot from "https://cdn.jsdelivr.net/npm/flowise-embed/dist/web.js";

    Chatbot.initFull({
      chatflowid: CHATFLOW_ID,
      apiHost: FLOWISE_API,
      theme: {
        chatWindow: {
          showTitle: false,                 // we use our own header
          showAgentMessages: true,
          welcomeMessage: 'سلام! من HMR هستم، مشاور سخت‌افزار موبایل. درباره خرید گوشی نو یا دست‌دوم، عیب‌یابی، آموزش سخت‌افزار، لوازم جانبی یا قیمت بپرس.',
          errorMessage: 'در حال حاضر به مشکل برخوردم. لطفاً دوباره تلاش کن.',
          backgroundColor: 'transparent',
          height: '100%',
          width: '100%',
          fontSize: 16,
          starterPrompts: [],               // removes the three starter boxes
          starterPromptFontSize: 14,
          clearChatOnReload: false,
          sourceDocsTitle: 'منابع:',
          renderHTML: true,
          botMessage: {
            backgroundColor: 'rgba(18,26,48,0.65)',
            textColor: '#eaf2ff',
            showAvatar: false
          },
          userMessage: {
            backgroundColor: '#2f6bff',
            textColor: '#ffffff',
            showAvatar: false
          },
          textInput: {
            placeholder: 'Ask about any phone',   // per request (corrected typo)
            backgroundColor: 'rgba(14,20,38,0.65)',
            textColor: '#eaf2ff',
            sendButtonColor: '#00d4ff',
            autoFocus: true,
            sendMessageSound: false,
            receiveMessageSound: false
          },
          feedback: { color: '#b9c6e4' },
          dateTimeToggle: { date: false, time: false },
          footer: {
            textColor: '#8a96b3',
            text: 'Powered by',
            company: 'HMR',
            companyLink: 'https://hmrbot.com'
          },
          // Inject RTL + Persian font into the widget's shadow DOM
          customCSS: `
            * { font-family: 'Vazirmatn', system-ui, sans-serif !important; }
            .chatbot-host-bubble, .chatbot-guest-bubble { direction: rtl; text-align: right; }
            input, textarea { direction: rtl; }
          `
        }
      }
    });
  </script>

  <!-- Neural particle field -->
  <script is:inline>
    (function () {
      var c = document.getElementById('particles');
      if (!c) return;
      var ctx = c.getContext('2d');
      var nodes = [], W, H, DPR = Math.min(window.devicePixelRatio || 1, 2);
      var LINK = 150;
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function resize() {
        W = c.clientWidth; H = c.clientHeight;
        c.width = W * DPR; c.height = H * DPR;
        ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
        var n = Math.round(Math.min(90, (W * H) / 16000));
        nodes = [];
        for (var i = 0; i < n; i++) {
          nodes.push({
            x: Math.random() * W, y: Math.random() * H,
            vx: (Math.random() - .5) * .32, vy: (Math.random() - .5) * .32,
            r: Math.random() * 1.6 + .8,
            pulse: Math.random() * Math.PI * 2
          });
        }
      }

      function draw() {
        ctx.clearRect(0, 0, W, H);
        for (var i = 0; i < nodes.length; i++) {
          var a = nodes[i];
          if (!reduce) {
            a.x += a.vx; a.y += a.vy; a.pulse += .02;
            if (a.x < 0 || a.x > W) a.vx *= -1;
            if (a.y < 0 || a.y > H) a.vy *= -1;
          }
          for (var j = i + 1; j < nodes.length; j++) {
            var b = nodes[j], dx = a.x - b.x, dy = a.y - b.y;
            var d = Math.sqrt(dx*dx + dy*dy);
            if (d < LINK) {
              ctx.strokeStyle = 'rgba(0,212,255,' + ((1 - d/LINK) * .5).toFixed(3) + ')';
              ctx.lineWidth = .7;
              ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
            }
          }
        }
        for (var k = 0; k < nodes.length; k++) {
          var node = nodes[k];
          var glow = .55 + .45 * Math.sin(node.pulse);
          ctx.beginPath();
          ctx.arc(node.x, node.y, node.r, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(92,225,255,' + (.35 + glow * .45).toFixed(3) + ')';
          ctx.shadowColor = 'rgba(0,212,255,.8)'; ctx.shadowBlur = 6;
          ctx.fill(); ctx.shadowBlur = 0;
        }
        if (!reduce) requestAnimationFrame(draw);
      }

      window.addEventListener('resize', resize);
      resize();
      draw();
    })();
  </script>
</body>
</html>
